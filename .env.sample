## CONFIGURATION 
RANSOMWARELIVE_HOME=.
WATERMARK_IMAGE_PATH=/images/ransomwarelive.png # Path to your watermark image
SCREENSHOT_DIR=/images/screenshots/
TOR_PROXY_SERVER=socks5://127.0.0.1:9050
DB_DIR=/db/
IMAGES_DIR=/images/
TMP_DIR=/tmp/
DATA_DIR=/data/

# Scraping
SCRAPE_CONCURRENCY=1 # Number of simultaneous scraping tasks (1 is safest for Tor)
PLAYWRIGHT_BROWSER=firefox # Use firefox, chromium, or webkit (Firefox is often more reliable on Tor)

# BlueSky
BLUESKY_ENABLED=false
BLUESKY_URL=https://bsky.social/xrpc/com.atproto.server.createSession
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password

# Pushover 
PUSHOVER_ENABLED=false # Set to true to enable real-time push notifications
PUSH_USER=your-user-key
PUSH_API=your-api-token

# AI Provider Selection (openai, gemini, or anthropic)
AI_PROVIDER=openai
AI_ENRICHMENT_ENABLED=true # Use AI to infer sector, description, and country from victim data
AI_CAPTCHA_SOLVING_ENABLED=false # Use AI Vision to solve CAPTCHAs during scraping (OpenAI or Gemini recommended)

# OpenAI (Models: gpt-4o, gpt-4-turbo)
OPENAI_API_KEY=
OPENAI_MODEL='gpt-4o' 

# Gemini (Models: models/gemini-2.5-flash, models/gemini-2.0-flash-exp)
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.5-flash

# Anthropic (Models: claude-3-5-sonnet-20241022, claude-3-opus-20240229)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# HudsonRock
HUDSONROCK_ENABLED=false

## Mail (SMTP configuration for alerts)
SMTP_SERVER=localhost
SMTP_PORT=25
EMAIL_FROM=noreply@ransomware.live
EMAIL_TO=support@ransomware.live

# Telegram (For monitoring groups or channels)
T_API_ID=
T_API_HASH=
T_PHONE_NUMBER=

# NTFY (Push notifications via ntfy.sh)
NTFY_ENABLED=false
NTFY_URL=https://ntfy.sh
NTFY_TOKEN=your-ntfy-token

# Screenshots
AUTO_SCREENSHOT_VICTIMS=false # Set to true to automatically capture screenshots of victims
AUTO_SCREENSHOT_GROUPS=false # Set to true to automatically capture screenshots of groups during scraping
USE_WATERMARK=true # Set to true to add a watermark to captured screenshots

# Duplicate tracking
LOCAL_DUPLICATES=true # Set to true to store original post title for duplicates; false to store a link

# TOR Management
TOR_PASSWORD= # Required if using control port (SIGNAL RELOAD)
TOR_AUTO_MANAGE=false # Set to true to start/stop the Tor process automatically
TOR_BINARY_PATH=tor # Path to the Tor binary (e.g., C:\\tor\\tor.exe on Windows)
TOR_TORRC_PATH= # Optional: Path to a custom torrc file

# Local examples:
# macOS Homebrew: TOR_BINARY_PATH=/opt/homebrew/bin/tor
# Windows: TOR_BINARY_PATH=C:\\tor\\tor.exe
