## CONFIGURATION 
RANSOMWARELIVE_HOME=.
WATERMARK_IMAGE_PATH=/images/ransomwarelive.png # Path to your watermark image
SCREENSHOT_DIR=/images/screenshots/
TOR_PROXY_SERVER=socks5://127.0.0.1:9050
DB_DIR=/db/
IMAGES_DIR=/images/
TMP_DIR=/tmp/
DATA_DIR=/data/

# Scraping
SCRAPE_CONCURRENCY=1 # Number of simultaneous scraping tasks (1 is safest for Tor)

# BlueSky
BLUESKY_ENABLED=false
BLUESKY_URL=
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Pushover 
PUSHOVER_ENABLED=false # Set to true to enable real-time push notifications
PUSH_USER=
PUSH_API=

# AI Provider (openai or gemini)
AI_PROVIDER=openai
AI_ENRICHMENT_ENABLED=true # Use AI to infer sector, description, and country
AI_CAPTCHA_SOLVING_ENABLED=false # Use AI Vision to solve CAPTCHAs during scraping

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL='gpt-4o' 

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.5-flash
 

# HudsonRock
HUDSONROCK_ENABLED=false

## Mail 
SMTP_SERVER=
SMTP_PORT=
EMAIL_FROM=
EMAIL_TO=

#Telegram 
T_API_ID=
T_API_HASH=
T_PHONE_NUMBER=

# NTFY
NTFY_ENABLED=false
NTFY_URL=
NTFY_TOKEN=

# Screenshots
AUTO_SCREENSHOT=false # Set to true to automatically capture screenshots during scraping/parsing
USE_WATERMARK=true # Set to true to add a watermark to captured screenshots

# Duplicate tracking
LOCAL_DUPLICATES=true # Set to true to store the original post title for duplicates instead of a link

#TOR 
TOR_PASSWORD= # As in your /etc/tor/torrc 
TOR_AUTO_MANAGE=false # Set to true to start/stop Tor automatically
TOR_BINARY_PATH=tor # Path to the Tor binary (e.g., C:\Path\To\tor.exe)
TOR_TORRC_PATH= # Optional: Path to your torrc file
